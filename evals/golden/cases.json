[
  {
    "id": "case_01_translation",
    "description": "Verifies that missing Russian translation is generated by Gemini.",
    "input": {
      "verse": {
        "id": "bhg_2_47_test",
        "s1": "karmaṇyevādhikāraste mā phaleṣu kadācana",
        "s2": "mā karmaphalaheturbhūr mā te saṅgo'stvakarmaṇi",
        "encoding": "IAST",
        "meter": "anuṣṭubh"
      }
    },
    "expected": {
      "phase": "validated",
      "checks": [
        "state['verse']['translation']['ru'] is not None",
        "len(state['verse']['translation']['ru']) > 20"
      ]
    },
    "requires_api": true
  },
  {
    "id": "case_02_meter_gate",
    "description": "Verifies that QualityGate rejects verses with unknown meter.",
    "input": {
      "verse": {
        "id": "unknown_meter_test",
        "s1": "abc def ghi jkl",
        "s2": "mno pqr stu vwx",
        "encoding": "IAST",
        "meter": "unknown"
      }
    },
    "expected": {
      "phase": "rejected",
      "checks": [
        "'Meter must be identified' in ''.join(state['errors'])"
      ]
    }
  },
  {
    "id": "case_03_id_format",
    "description": "Ensures IDs with spaces are rejected.",
    "input": {
      "verse": {
        "id": "invalid id with spaces",
        "s1": "śravaṇam kīrtanam viṣṇoḥ smaraṇam pādasevanam",
        "s2": "arcanam vandanam dāsyam sakhyamātmanivedanam",
        "encoding": "IAST",
        "meter": "anuṣṭubh"
      }
    },
    "expected": {
      "phase": "rejected",
      "checks": [
        "'must not contain spaces' in ''.join(state['errors'])"
      ]
    }
  },
  {
    "id": "case_04_tags",
    "description": "Verifies that relevant tags are added for famous verses.",
    "input": {
      "verse": {
        "id": "bhg_2_47_tags",
        "s1": "karmaṇyevādhikāraste mā phaleṣu kadācana",
        "s2": "mā karmaphalaheturbhūr mā te saṅgo'stvakarmaṇi",
        "encoding": "IAST",
        "meter": "anuṣṭubh"
      }
    },
    "expected": {
      "phase": "validated",
      "checks": [
        "len(state['verse'].get('tags', [])) >= 2"
      ]
    },
    "requires_api": true
  },
  {
    "id": "case_05_curator_validation",
    "description": "Verifies that missing mandatory fields are caught by Curator.",
    "input": {
      "verse": {
        "id": "missing_fields_test",
        "s1": "test line 1",
        "encoding": "IAST"
      }
    },
    "expected": {
      "phase": "curation_failed",
      "checks": [
        "'Missing mandatory field: s2' in ''.join(state['errors'])"
      ]
    }
  }
