[
  {
    "id": "case_01_translation",
    "description": "Verifies that missing Russian translation is generated by Gemini.",
    "input": {
      "verse": {
        "id": "bhg_2_47_test",
        "s1": "karmaṇyevādhikāraste mā phaleṣu kadācana",
        "s2": "mā karmaphalaheturbhūr mā te saṅgo'stvakarmaṇi",
        "encoding": "IAST",
        "meter": "anuṣṭubh"
      }
    },
    "expected": {
      "phase": "validated",
      "checks": [
        "state['verse']['translation']['ru'] is not None",
        "len(state['verse']['translation']['ru']) > 20"
      ]
    },
    "requires_api": true
  },
  {
    "id": "case_02_meter_gate",
    "description": "Verifies that QualityGate rejects verses with unknown meter.",
    "input": {
      "verse": {
        "id": "unknown_meter_test",
        "s1": "abc def ghi jkl",
        "s2": "mno pqr stu vwx",
        "encoding": "IAST",
        "meter": "unknown"
      }
    },
    "expected": {
      "phase": "rejected",
      "checks": [
        "'Meter must be identified' in ''.join(state['errors'])"
      ]
    }
  },
  {
    "id": "case_03_id_format",
    "description": "Ensures IDs with spaces are rejected.",
    "input": {
      "verse": {
        "id": "invalid id with spaces",
        "s1": "śravaṇam kīrtanam viṣṇoḥ smaraṇam pādasevanam",
        "s2": "arcanam vandanam dāsyam sakhyamātmanivedanam",
        "encoding": "IAST",
        "meter": "anuṣṭubh"
      }
    },
    "expected": {
      "phase": "rejected",
      "checks": [
        "'must not contain spaces' in ''.join(state['errors'])"
      ]
    }
  },
  {
    "id": "case_04_tags",
    "description": "Verifies that relevant tags are added for famous verses.",
    "input": {
      "verse": {
        "id": "bhg_2_47_tags",
        "s1": "karmaṇyevādhikāraste mā phaleṣu kadācana",
        "s2": "mā karmaphalaheturbhūr mā te saṅgo'stvakarmaṇi",
        "encoding": "IAST",
        "meter": "anuṣṭubh"
      }
    },
    "expected": {
      "phase": "validated",
      "checks": [
        "len(state['verse'].get('tags', [])) >= 2"
      ]
    },
    "requires_api": true
  },
  {
    "id": "case_05_curator_validation",
    "description": "Verifies that missing mandatory fields are caught by Curator.",
    "input": {
      "verse": {
        "id": "missing_fields_test",
        "s1": "test line 1",
        "encoding": "IAST"
      }
    },
    "expected": {
      "phase": "curation_failed",
      "checks": [
        "'Missing mandatory field: s2' in ''.join(state['errors'])"
      ]
    }
  },
  {
    "id": "case_06_duplicate_id",
    "description": "Verifies that existing verse IDs are rejected by QualityGate.",
    "input": {
      "verse": {
        "id": "bhg_2_47",
        "s1": "duplicate check verse text",
        "s2": "duplicate check verse text",
        "encoding": "IAST",
        "meter": "anuṣṭubh",
        "translation": {"ru": "Тест", "en": "Test"}
      }
    },
    "expected": {
      "phase": "rejected",
      "checks": [
        "'already exists' in ''.join(state['errors'])"
      ]
    }
  },
  {
    "id": "case_07_script_validation",
    "description": "Verifies that non-IAST characters in IAST field are rejected.",
    "input": {
      "verse": {
        "id": "cyrillic_test",
        "s1": "кириллица в санскрите",
        "s2": "more cyrillic text",
        "encoding": "IAST",
        "meter": "anuṣṭubh",
        "translation": {"ru": "Тест", "en": "Test"}
      }
    },
    "expected": {
      "phase": "rejected",
      "checks": [
        "'Invalid characters' in ''.join(state['errors'])"
      ]
    }
  },
  {
    "id": "case_08_version_check",
    "description": "Verifies that verse version must be an integer.",
    "input": {
      "verse": {
        "id": "v_test",
        "s1": "karmaṇyevādhikāraste mā phaleṣu kadācana",
        "s2": "mā karmaphalaheturbhūr mā te saṅgo'stvakarmaṇi",
        "encoding": "IAST",
        "meter": "anuṣṭubh",
        "version": "not-an-integer",
        "translation": {"ru": "Тест", "en": "Test"}
      }
    },
    "expected": {
      "phase": "rejected",
      "checks": [
        "'Schema violation' in ''.join(state['errors'])"
      ]
    }
  }
